<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional JD Generator</title>
    <style>
        :root {
            --primary-color: #2563eb;
            --bg-gray: #f3f4f6;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-gray);
            margin: 0;
            display: flex;
            height: 100vh;
        }

        /* Sidebar Form */
        .sidebar {
            width: 400px;
            background: white;
            padding: 20px;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
            overflow-y: auto;
            z-index: 10;
        }

        h2 { color: #1f2937; margin-top: 0; }
        
        .form-group { margin-bottom: 15px; }
        
        label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 5px;
            color: #374151;
        }

        input, select, textarea {
            width: 100%;
            padding: 8px;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .btn-generate {
            width: 100%;
            padding: 12px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 10px;
        }

        .btn-generate:hover { opacity: 0.9; }

        /* Preview Area */
        .preview-container {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
            display: flex;
            justify-content: center;
        }

        .jd-paper {
            width: 100%;
            max-width: 800px;
            background: white;
            min-height: 1000px;
            padding: 50px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            border-top: 10px solid var(--primary-color);
        }

        /* JD Styling */
        .jd-header { border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px; }
        .company-name { font-size: 1.2em; color: #666; text-transform: uppercase; letter-spacing: 1px; }
        .job-title { font-size: 2.5em; color: var(--primary-color); margin: 10px 0; }
        .tag-container { display: flex; gap: 10px; margin-top: 10px; }
        .tag { background: #f0f7ff; color: var(--primary-color); padding: 5px 12px; border-radius: 20px; font-size: 0.9em; font-weight: 500; }
        
        .section-title { color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 5px; margin-top: 30px; }
        .content { line-height: 1.6; color: #4b5563; }
        
        .incentive-box { 
            background: #fafafa; 
            padding: 15px; 
            border-left: 4px solid var(--primary-color);
            margin-top: 20px;
        }

        @media print {
            .sidebar { display: none; }
            .preview-container { padding: 0; }
            .jd-paper { box-shadow: none; border: none; }
        }
    </style>
</head>
<body>

<div class="sidebar">
    <h2>JD Builder</h2>
    
    <div class="form-group">
        <label>Theme Color</label>
        <input type="color" id="themeColor" value="#2563eb" onchange="updateColor()">
    </div>

    <div class="form-group">
        <label>Organization Name</label>
        <input type="text" id="orgName" placeholder="e.g. Acme Corp">
    </div>

    <div class="form-group">
        <label>Role Title</label>
        <input type="text" id="roleTitle" placeholder="e.g. Frontend Developer">
    </div>

    <div class="form-group">
        <label>Role Type</label>
        <select id="roleType">
            <option value="Full Time">Full Time</option>
            <option value="Internship">Internship</option>
            <option value="Apprenticeship">Apprenticeship</option>
            <option value="Fellowship">Fellowship</option>
            <option value="Articleship">Articleship</option>
            <option value="Volunteering">Volunteering</option>
        </select>
    </div>

    <div class="form-group">
        <label>Nature</label>
        <select id="nature" onchange="toggleLocation()">
            <option value="In-Office">In-Office</option>
            <option value="Hybrid">Hybrid</option>
            <option value="Work from Home">Work from Home</option>
        </select>
    </div>

    <div class="form-group" id="locationGroup">
        <label>Location</label>
        <input type="text" id="location" placeholder="e.g. New York, NY">
    </div>

    <div class="form-group">
        <label>Incentives</label>
        <input type="text" id="stipend" placeholder="Stipend (e.g. $500/mo)">
        <input type="text" id="ctc" placeholder="CTC (e.g. $80k/year)" style="margin-top:5px">
    </div>

    <div class="form-group">
        <label>Job Overview</label>
        <textarea id="overview" rows="3"></textarea>
    </div>

    <div class="form-group">
        <label>Responsibilities (One per line)</label>
        <textarea id="responsibilities" rows="4"></textarea>
    </div>

    <div class="form-group">
        <label>Requirements (One per line)</label>
        <textarea id="requirements" rows="4"></textarea>
    </div>

    <button class="btn-generate" onclick="generateJD()">Update Preview</button>
    <button class="btn-generate" style="background: #10b981;" onclick="window.print()">Download as PDF</button>
</div>

<div class="preview-container">
    <div class="jd-paper" id="jdContent">
        <div class="jd-header">
            <div class="company-name" id="pOrgName">ORGANIZATION NAME</div>
            <h1 class="job-title" id="pTitle">Job Role Title</h1>
            <div class="tag-container" id="pTags">
                <span class="tag">Full Time</span>
                <span class="tag">Remote</span>
            </div>
        </div>

        <h3 class="section-title">About the Role</h3>
        <p class="content" id="pOverview">Select options on the left to begin generating your professional job description.</p>

        <h3 class="section-title">Key Responsibilities</h3>
        <ul class="content" id="pResList">
            <li>Responsibility details will appear here.</li>
        </ul>

        <h3 class="section-title">What We're Looking For</h3>
        <ul class="content" id="pReqList">
            <li>Requirement details will appear here.</li>
        </ul>

        <div class="incentive-box" id="pIncentives">
            <strong>Incentives:</strong><br>
            <span id="pStipendText"></span><br>
            <span id="pCtcText"></span>
        </div>
    </div>
</div>

<script>
    function updateColor() {
        const color = document.getElementById('themeColor').value;
        document.documentElement.style.setProperty('--primary-color', color);
    }

    function toggleLocation() {
        const nature = document.getElementById('nature').value;
        const locGroup = document.getElementById('locationGroup');
        locGroup.style.display = (nature === 'Work from Home') ? 'none' : 'block';
    }

    function generateJD() {
        // Basic Info
        document.getElementById('pOrgName').innerText = document.getElementById('orgName').value || "Your Company Name";
        document.getElementById('pTitle').innerText = document.getElementById('roleTitle').value || "Job Role Title";
        
        // Tags
        const tags = [
            document.getElementById('roleType').value,
            document.getElementById('nature').value,
            document.getElementById('location').value
        ].filter(t => t && t !== 'Work from Home');
        
        const tagContainer = document.getElementById('pTags');
        tagContainer.innerHTML = '';
        tags.forEach(t => {
            const span = document.createElement('span');
            span.className = 'tag';
            span.innerText = t;
            tagContainer.appendChild(span);
        });

        // Overview
        document.getElementById('pOverview').innerText = document.getElementById('overview').value || "No overview provided.";

        // Lists
        const formatList = (inputId, targetId) => {
            const lines = document.getElementById(inputId).value.split('\n').filter(l => l.trim() !== '');
            const target = document.getElementById(targetId);
            target.innerHTML = lines.length ? lines.map(l => `<li>${l}</li>`).join('') : '<li>Details not provided.</li>';
        };

        formatList('responsibilities', 'pResList');
        formatList('requirements', 'pReqList');

        // Incentives
        const stipend = document.getElementById('stipend').value;
        const ctc = document.getElementById('ctc').value;
        document.getElementById('pStipendText').innerText = stipend ? `Stipend: ${stipend}` : '';
        document.getElementById('pCtcText').innerText = ctc ? `CTC: ${ctc}` : '';
        
        document.getElementById('pIncentives').style.display = (stipend || ctc) ? 'block' : 'none';
    }
</script>

</body>
</html>
